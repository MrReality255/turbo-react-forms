{
    "name": "@mrreality255/turbo-react-forms",
    "version": "0.2.3",
    "author": "Martin Mojzis",
    "type": "module",
    "main": "./dist/index.umd.js",
    "module": "./dist/index.es.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.es.js",
            "require": "./dist/index.umd.js"
        },
        "./style.css": "./dist/index.css"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite --config vite.demo.config.ts",
        "build": "tsc && vite build --config vite.config.ts",
        "build-lib": "tsc && vite build --config vite.config.ts",
        "build-demo": "tsc && vite build --config vite.demo.config.ts",
        "build-all": "tsc && vite build --config vite.config.ts && vite build --config vite.demo.config.ts",
        "lint": "eslint .",
        "preview": "vite preview",
        "format": "prettier --write .",
        "test": "vitest --run --config vitest.config.ts --pool=forks --reporter=verbose",
        "test:watch": "vitest --config vitest.config.ts --pool=forks --reporter=verbose"
    },
    "peerDependencies": {
        "luxon": "^3.0.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0"
    },
    "peerDependenciesMeta": {
        "luxon": {
            "optional": true
        }
    },
    "devDependencies": {
        "@eslint/js": "^9.36.0",
        "@types/luxon": "^3.0.0",
        "@types/node": "^24.6.0",
        "@types/react": "^19.2.2",
        "@types/react-dom": "^19.2.2",
        "@vitejs/plugin-react": "^5.1.0",
        "@vitest/coverage-v8": "^4.1.10",
        "eslint": "^9.38.0",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.22",
        "globals": "^16.4.0",
        "prettier": "^3.6.2",
        "react-router-dom": "^7.9.5",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.45.0",
        "vite": "^7.1.12",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.1.10",
        "luxon": "^3.0.0"
    }
}
